{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["spool", "crawler"],
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Spool — Crawler",
  "uid": "spool-crawler-v1",
  "version": 1,

  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
        "definition": "label_values(spool_crawler_events_total, service_name)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Node",
        "multi": true,
        "name": "node",
        "options": [],
        "query": {
          "qryType": 1,
          "query": "label_values(spool_crawler_events_total, service_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
        "definition": "label_values(spool_crawler_events_total{service_name=~\"$node\"}, source)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Source",
        "multi": true,
        "name": "source",
        "options": [],
        "query": {
          "qryType": 1,
          "query": "label_values(spool_crawler_events_total{service_name=~\"$node\"}, source)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Throughput",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "Events captured / s",
      "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table", "placement": "bottom", "showLegend": true,
          "calcs": ["lastNotNull", "mean", "max"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "sum by (service_name, source) (rate(spool_crawler_events_total{service_name=~\"$node\", source=~\"$source\", status=\"success\"}[1m]))",
          "legendFormat": "{{service_name}} / {{source}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 }
    },

    {
      "id": 3,
      "type": "timeseries",
      "title": "Errors (total since startup)",
      "description": "Cumulative error counter since process startup. Rises when errors occur, flat otherwise.",
      "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table", "placement": "bottom", "showLegend": true,
          "calcs": ["lastNotNull", "max"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "sum by (service_name, source) (spool_crawler_errors_total{service_name=~\"$node\", source=~\"$source\"})\nor\n0 * sum by (service_name, source) (spool_crawler_events_total{service_name=~\"$node\", source=~\"$source\", status=\"success\"})",
          "legendFormat": "{{service_name}} / {{source}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 }
    },

    {
      "id": 4,
      "type": "row",
      "title": "Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "End-to-end latency (p50 / p95 / p99)",
      "description": "Time from payload detection to ingester delivery, in seconds.",
      "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table", "placement": "bottom", "showLegend": true,
          "calcs": ["lastNotNull", "mean", "max"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "histogram_quantile(0.5, sum by (le, service_name, source) (rate(spool_crawler_latency_bucket{service_name=~\"$node\", source=~\"$source\"}[1m])))",
          "legendFormat": "p50 — {{service_name}} / {{source}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, service_name, source) (rate(spool_crawler_latency_bucket{service_name=~\"$node\", source=~\"$source\"}[1m])))",
          "legendFormat": "p95 — {{service_name}} / {{source}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le, service_name, source) (rate(spool_crawler_latency_bucket{service_name=~\"$node\", source=~\"$source\"}[1m])))",
          "legendFormat": "p99 — {{service_name}} / {{source}}",
          "refId": "C"
        }
      ],
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 }
    },

    {
      "id": 6,
      "type": "row",
      "title": "Payload",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Payload size p90",
      "description": "Size in bytes of captured payloads at the 90th percentile.",
      "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table", "placement": "bottom", "showLegend": true,
          "calcs": ["lastNotNull", "mean", "max"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "histogram_quantile(0.9, sum by (le, service_name, source) (rate(spool_crawler_payload_size_bucket{service_name=~\"$node\", source=~\"$source\"}[1m])))",
          "legendFormat": "p90 — {{service_name}} / {{source}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 }
    },

    {
      "id": 8,
      "type": "stat",
      "title": "Error rate (%)",
      "description": "Percentage of events that ended in error within the selected time window.",
      "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "100 *\n(\n  sum(spool_crawler_events_total{service_name=~\"$node\", source=~\"$source\", status=\"error\"})\n  or vector(0)\n)\n/\nclamp_min(\n  sum(spool_crawler_events_total{service_name=~\"$node\", source=~\"$source\"})\n  or vector(0),\n  1e-9\n)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 }
    },

    {
      "id": 13,
      "type": "stat",
      "title": "Total events",
      "description": "Cumulative total of successfully processed events since process startup.",
      "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": 0 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "sum by (service_name, source) (spool_crawler_events_total{service_name=~\"$node\", source=~\"$source\"})",
          "legendFormat": "{{service_name}} / {{source}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 28 }
    }

  ]
}
