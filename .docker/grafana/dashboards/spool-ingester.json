{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["spool", "ingester"],
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Spool — Ingester",
  "uid": "spool-ingester-v1",
  "version": 1,

  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
        "definition": "label_values(spool_ingester_records_total, service_name)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Nodo",
        "multi": true,
        "name": "node",
        "options": [],
        "query": {
          "qryType": 1,
          "query": "label_values(spool_ingester_records_total, service_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Throughput",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Registros ingestados",
      "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": 0 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "sum(spool_ingester_records_total{service_name=~\"$node\"})\nor vector(0)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Registros rechazados",
      "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red",   "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "sum(spool_ingester_records_rejected_total{service_name=~\"$node\"})\nor vector(0)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Tasa de rechazo (%)",
      "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "100 *\n(\n  sum(spool_ingester_records_rejected_total{service_name=~\"$node\"})\n  or vector(0)\n)\n/\nclamp_min(\n  (\n    sum(spool_ingester_records_total{service_name=~\"$node\"})\n    or vector(0)\n  )\n  +\n  (\n    sum(spool_ingester_records_rejected_total{service_name=~\"$node\"})\n    or vector(0)\n  ),\n  1e-9\n)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 1 }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Registros ingestados / s",
      "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table", "placement": "bottom", "showLegend": true,
          "calcs": ["lastNotNull", "mean", "max"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "sum by (service_name) (rate(spool_ingester_records_total{service_name=~\"$node\", status=\"success\"}[1m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Registros rechazados / s",
      "description": "Ritmo de rechazos por motivo: invalid (validación) y quarantine (cuarentena).",
      "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table", "placement": "bottom", "showLegend": true,
          "calcs": ["lastNotNull", "mean", "max"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "sum by (service_name, reason) (rate(spool_ingester_records_rejected_total{service_name=~\"$node\"}[1m]))",
          "legendFormat": "{{service_name}} / {{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 }
    },

    {
      "id": 7,
      "type": "row",
      "title": "Latencia",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Duración de procesamiento (p50 / p95 / p99)",
      "description": "Tiempo desde recepción del evento hasta finalización del pipeline por batch.",
      "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table", "placement": "bottom", "showLegend": true,
          "calcs": ["lastNotNull", "mean", "max"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "histogram_quantile(0.5, sum by (le, service_name) (rate(spool_ingester_processing_duration_bucket{service_name=~\"$node\"}[1m])))",
          "legendFormat": "p50 — {{service_name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(spool_ingester_processing_duration_bucket{service_name=~\"$node\"}[1m])))",
          "legendFormat": "p95 — {{service_name}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "spool-prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le, service_name) (rate(spool_ingester_processing_duration_bucket{service_name=~\"$node\"}[1m])))",
          "legendFormat": "p99 — {{service_name}}",
          "refId": "C"
        }
      ],
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 14 }
    }

  ]
}
